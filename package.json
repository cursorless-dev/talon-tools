{
    "name": "@cursorless/talon-tools",
    "version": "0.3.0",
    "description": "Linting and formatting tools for Talon and Cursorless",
    "author": "Cursorless Dev",
    "license": "MIT",
    "type": "module",
    "files": [
        "out",
        "!out/test",
        "!out/cli",
        "!out/build.*"
    ],
    "types": "./out/lib.d.ts",
    "exports": {
        ".": {
            "types": "./out/lib.d.ts",
            "default": "./out/lib.js"
        }
    },
    "bin": {
        "snippet-fmt": "out/snippetFormatter.js",
        "talon-fmt": "out/talonFormatter.js",
        "tree-sitter-fmt": "out/treeSitterFormatter.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cursorless-dev/talon-tools.git"
    },
    "funding": "https://github.com/sponsors/cursorless-dev",
    "sponsor": {
        "url": "https://github.com/sponsors/cursorless-dev"
    },
    "scripts": {
        "build": "tsc -p . && tsx ./src/build.ts",
        "clean": "rm -rf out",
        "lint": "npm run lint:ts &&npm run lint:fmt",
        "lint:ts": "tsc -p . --noEmit && eslint src",
        "lint:fmt": "prettier --check .",
        "fix": "npm run fix:ts && npm run fix:fmt",
        "fix:ts": "eslint src --fix",
        "fix:fmt": "prettier --write --list-different .",
        "test": "tsx src/test/runAllTests.ts"
    },
    "dependencies": {
        "@cursorless/tree-sitter-wasms": "^0.7.0",
        "editorconfig": "^3.0.2",
        "fast-glob": "^3.3.3",
        "get-stdin": "^10.0.0",
        "web-tree-sitter": "^0.26.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.12.0",
        "esbuild": "^0.27.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint": "^10.0.3",
        "jiti": "^2.6.1",
        "mocha": "^11.7.5",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript-eslint": "^8.57.0",
        "typescript": "^5.9.3"
    }
}
