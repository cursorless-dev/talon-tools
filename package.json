{
    "name": "pre-commit-hooks",
    "displayName": "Pre-commit hooks",
    "version": "0.1.0",
    "license": "MIT",
    "files": [
        "out/*",
        "LICENSE"
    ],
    "exports": {
        ".": "./out/lib.js"
    },
    "bin": {
        "talonfmt": "./out/talonfmt.js"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/AndreasArvidsson/pre-commit-hooks"
    },
    "sponsor": {
        "url": "https://github.com/sponsors/AndreasArvidsson"
    },
    "funding": "https://github.com/sponsors/AndreasArvidsson",
    "scripts": {
        "prepack": "npm run build",
        "build": "tsx ./src/build.ts",
        "clean": "rm -rf out",
        "lint": "npm run lint:fmt && npm run lint:ts",
        "lint:fmt": "prettier --check .",
        "lint:ts": "tsc -p . && eslint src",
        "fix": "npm run fix:fmt && npm run fix:ts",
        "fix:fmt": "prettier --write --list-different .",
        "fix:ts": "eslint src --fix",
        "test": "tsx src/test/runAllTests.ts"
    },
    "dependencies": {
        "@cursorless/tree-sitter-wasms": "^0.7.0",
        "talon-snippets": "^1.3.0",
        "web-tree-sitter": "^0.26.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.12.0",
        "esbuild": "^0.27.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint": "^10.0.3",
        "glob": "^13.0.6",
        "jiti": "^2.6.1",
        "mocha": "^11.7.5",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript-eslint": "^8.56.1",
        "typescript": "^5.9.3"
    }
}
